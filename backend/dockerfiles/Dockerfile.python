# python-sandbox Dockerfile
FROM python:3.11-slim

# Set the working directory inside the container
WORKDIR /sandbox

# Install pip and other dependencies (if needed)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential python3-setuptools python3-dev \
    python3-pip python3-wheel \
    && rm -rf /var/lib/apt/lists/*

# Add requirements.txt (if exists) to the container
COPY requirements.txt /sandbox/

# Install dependencies if requirements.txt is provided
RUN if [ -f "requirements.txt" ]; then pip install -r requirements.txt; fi

# Expose a port if needed (for web apps)
EXPOSE 8000

# Set entry point (this can be overridden at runtime)
CMD ["python"]
